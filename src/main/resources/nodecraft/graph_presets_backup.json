      "displayName": "节点组合",
      "presets": [
        {
          "id": "composite.textured_box",
          "displayName": "创建带材质的立方体",
          "description": "Box → Assign Block Type → Geometry Viewer",
          "kind": "composite",
          "nodes": [
            { "ref": "box", "typeId": "geometry.primitives.box", "x": 0, "y": 0 },
            { "ref": "material", "typeId": "material.basic_assignment.assign_block_type", "x": 300, "y": 0 },
            { "ref": "viewer", "typeId": "output.preview.geometry_viewer", "x": 600, "y": 0 }
          ],
          "connections": [
            { "fromRef": "box", "fromPort": "output_geometry", "toRef": "material", "toPort": "input_geometry" },
            { "fromRef": "material", "fromPort": "output_positions", "toRef": "viewer", "toPort": "input_blocks" }
          ]
        },
        {
          "id": "composite.array_transform_deform",
          "displayName": "阵列并变形",
          "description": "Box → Linear Array → Transform Geometry",
          "kind": "composite",
          "nodes": [
            { "ref": "box", "typeId": "geometry.primitives.box", "x": 0, "y": 0 },
            { "ref": "array", "typeId": "pattern.linear.linear_array_geometry", "x": 300, "y": 0 },
            { "ref": "transform", "typeId": "transform.basic_transforms.transform_geometry", "x": 600, "y": 0 }
          ],
          "connections": [
            { "fromRef": "box", "fromPort": "output_geometry", "toRef": "array", "toPort": "input_geometry" },
            { "fromRef": "array", "fromPort": "output_geometry", "toRef": "transform", "toPort": "input_geometry" }
          ]
        },
        {
          "id": "composite.boolean_cut_bake",
          "displayName": "布尔切割",
          "description": "Box A + Box B → Difference → Bake Geometry To Blocks",
          "kind": "composite",
          "nodes": [
            { "ref": "base", "typeId": "geometry.primitives.box", "x": 0, "y": 0 },
            { "ref": "cutter", "typeId": "geometry.primitives.box", "x": 0, "y": 180 },
            { "ref": "difference", "typeId": "geometry.boolean.difference", "x": 320, "y": 80 },
            { "ref": "bake", "typeId": "output.execute.bake_geometry_to_blocks", "x": 620, "y": 80 }
          ],
          "connections": [
            { "fromRef": "base", "fromPort": "output_geometry", "toRef": "difference", "toPort": "input_base" },
            { "fromRef": "cutter", "fromPort": "output_geometry", "toRef": "difference", "toPort": "input_cutter" },
            { "fromRef": "difference", "fromPort": "output_geometry", "toRef": "bake", "toPort": "input_geometry" }
          ]
        }
      ]
    }
