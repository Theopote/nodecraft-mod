{
  "preset_id": "decorative.fountain_circular",
  "version": "1.0.0",
  "schema_version": "1.0",

  "metadata": {
    "name": "Circular Fountain",
    "name_i18n": {
      "zh_CN": "圆形喷泉",
      "en_US": "Circular Fountain"
    },
    "description": "An elegant circular fountain with tiered basin and central spout.",
    "description_i18n": {
      "zh_CN": "优雅的圆形喷泉，带有分层水池和中央喷口。",
      "en_US": "An elegant circular fountain with tiered basin and central spout."
    },
    "author": "NodeCraft Team",
    "tags": ["fountain", "decorative", "water", "circular"],
    "category": "decorative",
    "difficulty": "beginner",
    "estimated_build_time": "3 minutes",
    "estimated_node_count": 10
  },

  "thumbnails": {
    "main": "thumbnail.png",
    "previews": []
  },

  "parameters": [
    {
      "id": "outer_radius",
      "name": "Outer Radius",
      "type": "integer",
      "default": 4,
      "min": 2,
      "max": 12,
      "step": 1,
      "description": "Radius of the outer basin",
      "group": "Dimensions"
    },
    {
      "id": "inner_radius",
      "name": "Inner Radius",
      "type": "integer",
      "default": 2,
      "min": 1,
      "max": 8,
      "step": 1,
      "description": "Radius of the inner raised tier",
      "group": "Dimensions"
    },
    {
      "id": "basin_depth",
      "name": "Basin Depth",
      "type": "integer",
      "default": 2,
      "min": 1,
      "max": 4,
      "step": 1,
      "description": "Depth of the water basin",
      "group": "Dimensions"
    },
    {
      "id": "center_spout_height",
      "name": "Spout Height",
      "type": "integer",
      "default": 3,
      "min": 1,
      "max": 8,
      "step": 1,
      "description": "Height of the center spout",
      "group": "Dimensions"
    },
    {
      "id": "basin_material",
      "name": "Basin Material",
      "type": "block_selector",
      "default": "minecraft:stone_bricks",
      "description": "Block type for basin structure",
      "group": "Materials"
    },
    {
      "id": "spout_material",
      "name": "Spout Material",
      "type": "block_selector",
      "default": "minecraft:quartz_pillar",
      "description": "Block type for center spout",
      "group": "Materials"
    },
    {
      "id": "water_material",
      "name": "Water Material",
      "type": "block_selector",
      "default": "minecraft:water",
      "description": "Block type for water",
      "group": "Materials"
    }
  },

  "graph": {
    "nodes": [
      {
        "id": "input_pos",
        "type": "input.context.player_position",
        "position": {"x": 50, "y": 300},
        "parameters": {}
      },
      {
        "id": "outer_basin",
        "type": "geometry.primitives.cylinder_by_axis_and_radius",
        "position": {"x": 250, "y": 200},
        "parameters": {
          "radius": {"param": "outer_radius"},
          "height": {"param": "basin_depth"},
          "axis": {"x": 0, "y": 1, "z": 0}
        }
      },
      {
        "id": "outer_hollow",
        "type": "geometry.primitives.cylinder_by_axis_and_radius",
        "position": {"x": 250, "y": 320},
        "parameters": {
          "radius": {"param": "outer_radius_minus_wall"},
          "height": {"param": "basin_depth_minus_floor"},
          "axis": {"x": 0, "y": 1, "z": 0}
        }
      },
      {
        "id": "subtract_outer",
        "type": "geometry.boolean.difference",
        "position": {"x": 450, "y": 260},
        "parameters": {}
      },
      {
        "id": "inner_tier",
        "type": "geometry.primitives.cylinder_by_axis_and_radius",
        "position": {"x": 250, "y": 450},
        "parameters": {
          "radius": {"param": "inner_radius"},
          "height": {"param": "inner_tier_height"},
          "axis": {"x": 0, "y": 1, "z": 0}
        }
      },
      {
        "id": "center_spout",
        "type": "geometry.primitives.cylinder_by_axis_and_radius",
        "position": {"x": 250, "y": 570},
        "parameters": {
          "radius": 0.3,
          "height": {"param": "center_spout_height"},
          "axis": {"x": 0, "y": 1, "z": 0}
        }
      },
      {
        "id": "union_structure",
        "type": "geometry.boolean.union_multiple",
        "position": {"x": 650, "y": 400},
        "parameters": {}
      },
      {
        "id": "assign_materials",
        "type": "material.basic_assignment.assign_block_type",
        "position": {"x": 850, "y": 400},
        "parameters": {
          "block_type": {"param": "basin_material"}
        }
      },
      {
        "id": "move_to_pos",
        "type": "transform.basic.move",
        "position": {"x": 1050, "y": 400},
        "parameters": {}
      },
      {
        "id": "bake",
        "type": "output.bake.geometry_to_blocks",
        "position": {"x": 1250, "y": 400},
        "parameters": {
          "placement_mode": "solid"
        }
      },
      {
        "id": "preview",
        "type": "output.preview.preview_blocks",
        "position": {"x": 1450, "y": 400},
        "parameters": {}
      }
    ],
    "connections": [
      {
        "from": {"node": "outer_basin", "port": "geometry"},
        "to": {"node": "subtract_outer", "port": "a"}
      },
      {
        "from": {"node": "outer_hollow", "port": "geometry"},
        "to": {"node": "subtract_outer", "port": "b"}
      },
      {
        "from": {"node": "subtract_outer", "port": "result"},
        "to": {"node": "union_structure", "port": "geometries"}
      },
      {
        "from": {"node": "inner_tier", "port": "geometry"},
        "to": {"node": "union_structure", "port": "geometries"}
      },
      {
        "from": {"node": "center_spout", "port": "geometry"},
        "to": {"node": "union_structure", "port": "geometries"}
      },
      {
        "from": {"node": "union_structure", "port": "result"},
        "to": {"node": "assign_materials", "port": "geometry"}
      },
      {
        "from": {"node": "assign_materials", "port": "geometry"},
        "to": {"node": "move_to_pos", "port": "geometry"}
      },
      {
        "from": {"node": "input_pos", "port": "position"},
        "to": {"node": "move_to_pos", "port": "translation"}
      },
      {
        "from": {"node": "move_to_pos", "port": "geometry"},
        "to": {"node": "bake", "port": "geometry"}
      },
      {
        "from": {"node": "bake", "port": "blocks"},
        "to": {"node": "preview", "port": "blocks"}
      }
    ]
  },

  "documentation": {
    "learning_notes": "This preset shows how to create hollow cylindrical structures using boolean difference, then combine multiple tiers with union operations.",
    "tips": [
      "Place in town squares or gardens",
      "Add water blocks manually after baking",
      "Use different stone types for varied looks",
      "Inner tier creates visual interest",
      "Center spout can be decorative or functional"
    ],
    "related_presets": [
      "decorative.statue_pedestal",
      "architectural.residential.medieval_cottage"
    ]
  }
}
