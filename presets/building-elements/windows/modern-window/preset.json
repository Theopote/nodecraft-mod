{
  "preset_id": "building_elements.windows.modern_window",
  "version": "1.0.0",
  "schema_version": "1.0",

  "metadata": {
    "name": "Modern Window",
    "name_i18n": {
      "zh_CN": "现代窗户",
      "en_US": "Modern Window"
    },
    "description": "A simple rectangular window with clean lines, perfect for contemporary buildings.",
    "description_i18n": {
      "zh_CN": "线条简洁的简单矩形窗户，非常适合现代建筑。",
      "en_US": "A simple rectangular window with clean lines, perfect for contemporary buildings."
    },
    "author": "NodeCraft Team",
    "tags": ["window", "modern", "rectangular", "building-element"],
    "category": "building_elements",
    "difficulty": "beginner",
    "estimated_build_time": "1 minute",
    "estimated_node_count": 5
  },

  "thumbnails": {
    "main": "thumbnail.png",
    "previews": []
  },

  "parameters": [
    {
      "id": "width",
      "name": "Window Width",
      "type": "integer",
      "default": 3,
      "min": 1,
      "max": 8,
      "step": 1,
      "description": "Width of the window",
      "group": "Dimensions"
    },
    {
      "id": "height",
      "name": "Window Height",
      "type": "integer",
      "default": 3,
      "min": 1,
      "max": 8,
      "step": 1,
      "description": "Height of the window",
      "group": "Dimensions"
    },
    {
      "id": "frame_thickness",
      "name": "Frame Thickness",
      "type": "integer",
      "default": 1,
      "min": 1,
      "max": 2,
      "step": 1,
      "description": "Thickness of window frame",
      "group": "Dimensions"
    },
    {
      "id": "frame_material",
      "name": "Frame Material",
      "type": "block_selector",
      "default": "minecraft:iron_block",
      "description": "Block type for window frame",
      "group": "Materials"
    },
    {
      "id": "glass_material",
      "name": "Glass Material",
      "type": "block_selector",
      "default": "minecraft:glass_pane",
      "description": "Block type for window glass",
      "group": "Materials"
    }
  },

  "graph": {
    "nodes": [
      {
        "id": "input_pos",
        "type": "input.context.player_position",
        "position": {"x": 50, "y": 200},
        "parameters": {}
      },
      {
        "id": "window_opening",
        "type": "geometry.primitives.box_by_corner_and_size",
        "position": {"x": 250, "y": 200},
        "parameters": {
          "corner": {"x": 0, "y": 0, "z": 0},
          "size": {
            "x": {"param": "width"},
            "y": {"param": "height"},
            "z": {"param": "frame_thickness"}
          }
        }
      },
      {
        "id": "assign_glass",
        "type": "material.basic_assignment.assign_block_type",
        "position": {"x": 450, "y": 200},
        "parameters": {
          "block_type": {"param": "glass_material"}
        }
      },
      {
        "id": "move_to_pos",
        "type": "transform.basic.move",
        "position": {"x": 650, "y": 200},
        "parameters": {}
      },
      {
        "id": "bake",
        "type": "output.bake.geometry_to_blocks",
        "position": {"x": 850, "y": 200},
        "parameters": {
          "placement_mode": "solid"
        }
      },
      {
        "id": "preview",
        "type": "output.preview.preview_blocks",
        "position": {"x": 1050, "y": 200},
        "parameters": {}
      }
    ],
    "connections": [
      {
        "from": {"node": "window_opening", "port": "geometry"},
        "to": {"node": "assign_glass", "port": "geometry"}
      },
      {
        "from": {"node": "assign_glass", "port": "geometry"},
        "to": {"node": "move_to_pos", "port": "geometry"}
      },
      {
        "from": {"node": "input_pos", "port": "position"},
        "to": {"node": "move_to_pos", "port": "translation"}
      },
      {
        "from": {"node": "move_to_pos", "port": "geometry"},
        "to": {"node": "bake", "port": "geometry"}
      },
      {
        "from": {"node": "bake", "port": "blocks"},
        "to": {"node": "preview", "port": "blocks"}
      }
    ]
  },

  "documentation": {
    "learning_notes": "This is the simplest window preset - just a glass-filled rectangle. Use it as a starting point or array multiple windows for larger facades.",
    "tips": [
      "Perfect for modern and minimalist designs",
      "Array horizontally for ribbon windows",
      "Use tinted glass for privacy",
      "Iron or concrete frames match modern aesthetics",
      "Adjust frame thickness to match wall depth"
    ],
    "related_presets": [
      "building_elements.windows.arched_window",
      "styles.modern.glass_box_building"
    ]
  }
}
