{
  "preset_id": "building_elements.columns.classical_column",
  "version": "1.0.0",
  "schema_version": "1.0",

  "metadata": {
    "name": "Classical Column",
    "name_i18n": {
      "zh_CN": "古典圆柱",
      "en_US": "Classical Column"
    },
    "description": "A classical architectural column with base, shaft, and capital.",
    "description_i18n": {
      "zh_CN": "带有基座、柱身和柱头的古典建筑圆柱。",
      "en_US": "A classical architectural column with base, shaft, and capital."
    },
    "author": "NodeCraft Team",
    "tags": ["column", "classical", "pillar", "architectural"],
    "category": "building_elements",
    "difficulty": "beginner",
    "estimated_build_time": "2 minutes",
    "estimated_node_count": 7
  },

  "thumbnails": {
    "main": "thumbnail.png",
    "previews": []
  },

  "parameters": [
    {
      "id": "height",
      "name": "Column Height",
      "type": "integer",
      "default": 8,
      "min": 4,
      "max": 24,
      "step": 1,
      "description": "Total height of the column",
      "group": "Dimensions"
    },
    {
      "id": "shaft_radius",
      "name": "Shaft Radius",
      "type": "float",
      "default": 0.6,
      "min": 0.4,
      "max": 1.5,
      "step": 0.1,
      "description": "Radius of the main shaft",
      "group": "Dimensions"
    },
    {
      "id": "base_height",
      "name": "Base Height",
      "type": "integer",
      "default": 1,
      "min": 0,
      "max": 3,
      "step": 1,
      "description": "Height of the base pedestal",
      "group": "Proportions"
    },
    {
      "id": "capital_height",
      "name": "Capital Height",
      "type": "integer",
      "default": 1,
      "min": 0,
      "max": 3,
      "step": 1,
      "description": "Height of the capital at top",
      "group": "Proportions"
    },
    {
      "id": "column_material",
      "name": "Column Material",
      "type": "block_selector",
      "default": "minecraft:quartz_pillar",
      "description": "Block type for the column",
      "group": "Materials"
    }
  ],

  "graph": {
    "nodes": [
      {
        "id": "input_pos",
        "type": "input.context.player_position",
        "position": {"x": 50, "y": 250},
        "parameters": {}
      },
      {
        "id": "base",
        "type": "geometry.primitives.cylinder_by_axis_and_radius",
        "position": {"x": 250, "y": 150},
        "parameters": {
          "radius": {"param": "base_radius_calc"},
          "height": {"param": "base_height"},
          "axis": {"x": 0, "y": 1, "z": 0}
        }
      },
      {
        "id": "shaft",
        "type": "geometry.primitives.cylinder_by_axis_and_radius",
        "position": {"x": 250, "y": 250},
        "parameters": {
          "radius": {"param": "shaft_radius"},
          "height": {"param": "shaft_height_calc"},
          "axis": {"x": 0, "y": 1, "z": 0}
        }
      },
      {
        "id": "capital",
        "type": "geometry.primitives.cylinder_by_axis_and_radius",
        "position": {"x": 250, "y": 350},
        "parameters": {
          "radius": {"param": "capital_radius_calc"},
          "height": {"param": "capital_height"},
          "axis": {"x": 0, "y": 1, "z": 0}
        }
      },
      {
        "id": "union_column",
        "type": "geometry.boolean.union_multiple",
        "position": {"x": 450, "y": 250},
        "parameters": {}
      },
      {
        "id": "assign_material",
        "type": "material.basic_assignment.assign_block_type",
        "position": {"x": 650, "y": 250},
        "parameters": {
          "block_type": {"param": "column_material"}
        }
      },
      {
        "id": "move_to_pos",
        "type": "transform.basic.move",
        "position": {"x": 850, "y": 250},
        "parameters": {}
      },
      {
        "id": "bake",
        "type": "output.bake.geometry_to_blocks",
        "position": {"x": 1050, "y": 250},
        "parameters": {
          "placement_mode": "solid"
        }
      },
      {
        "id": "preview",
        "type": "output.preview.preview_blocks",
        "position": {"x": 1250, "y": 250},
        "parameters": {}
      }
    ],
    "connections": [
      {
        "from": {"node": "base", "port": "geometry"},
        "to": {"node": "union_column", "port": "geometries"}
      },
      {
        "from": {"node": "shaft", "port": "geometry"},
        "to": {"node": "union_column", "port": "geometries"}
      },
      {
        "from": {"node": "capital", "port": "geometry"},
        "to": {"node": "union_column", "port": "geometries"}
      },
      {
        "from": {"node": "union_column", "port": "result"},
        "to": {"node": "assign_material", "port": "geometry"}
      },
      {
        "from": {"node": "assign_material", "port": "geometry"},
        "to": {"node": "move_to_pos", "port": "geometry"}
      },
      {
        "from": {"node": "input_pos", "port": "position"},
        "to": {"node": "move_to_pos", "port": "translation"}
      },
      {
        "from": {"node": "move_to_pos", "port": "geometry"},
        "to": {"node": "bake", "port": "geometry"}
      },
      {
        "from": {"node": "bake", "port": "blocks"},
        "to": {"node": "preview", "port": "blocks"}
      }
    ]
  },

  "documentation": {
    "learning_notes": "This preset demonstrates how to create compound structures by stacking cylindrical elements with different radii to achieve classical column proportions.",
    "tips": [
      "Classical proportions: base and capital slightly wider than shaft",
      "Use in colonnades and temple facades",
      "Quartz creates elegant white columns",
      "Stone bricks work for medieval settings",
      "Array multiple columns for porticos"
    ],
    "related_presets": [
      "quickstart.simple_tower",
      "architectural.residential.medieval_cottage"
    ]
  }
}
