{
  "preset_id": "building_elements.roofs.gable_roof",
  "version": "1.0.0",
  "schema_version": "1.0",

  "metadata": {
    "name": "Gable Roof",
    "name_i18n": {
      "zh_CN": "山墙屋顶",
      "en_US": "Gable Roof"
    },
    "description": "A classic gable (pitched) roof with adjustable pitch and overhang.",
    "description_i18n": {
      "zh_CN": "经典的山墙（斜坡）屋顶，可调节坡度和悬挑。",
      "en_US": "A classic gable (pitched) roof with adjustable pitch and overhang."
    },
    "author": "NodeCraft Team",
    "tags": ["roof", "gable", "pitched", "building-element"],
    "category": "building_elements",
    "difficulty": "beginner",
    "estimated_build_time": "2 minutes",
    "estimated_node_count": 8
  },

  "thumbnails": {
    "main": "thumbnail.png",
    "previews": []
  },

  "parameters": [
    {
      "id": "width",
      "name": "Building Width",
      "type": "integer",
      "default": 10,
      "min": 4,
      "max": 32,
      "step": 1,
      "description": "Width of the building (X direction)",
      "group": "Dimensions"
    },
    {
      "id": "length",
      "name": "Building Length",
      "type": "integer",
      "default": 12,
      "min": 4,
      "max": 32,
      "step": 1,
      "description": "Length of the building (Z direction)",
      "group": "Dimensions"
    },
    {
      "id": "pitch",
      "name": "Roof Pitch",
      "type": "float",
      "default": 0.7,
      "min": 0.3,
      "max": 1.5,
      "step": 0.1,
      "description": "Steepness of the roof (height per horizontal unit)",
      "group": "Shape"
    },
    {
      "id": "overhang",
      "name": "Overhang",
      "type": "integer",
      "default": 1,
      "min": 0,
      "max": 3,
      "step": 1,
      "description": "How far the roof extends beyond walls",
      "group": "Shape"
    },
    {
      "id": "roof_material",
      "name": "Roof Material",
      "type": "block_selector",
      "default": "minecraft:oak_stairs",
      "description": "Block type for the roof",
      "group": "Materials"
    }
  ],

  "graph": {
    "nodes": [
      {
        "id": "input_pos",
        "type": "input.context.player_position",
        "position": {"x": 50, "y": 200},
        "parameters": {}
      },
      {
        "id": "roof_profile",
        "type": "geometry.profiles.triangle",
        "position": {"x": 250, "y": 200},
        "parameters": {
          "width": {"param": "width_with_overhang"},
          "height": {"param": "roof_height_calc"}
        }
      },
      {
        "id": "extrude_roof",
        "type": "geometry.solids.extrude",
        "position": {"x": 450, "y": 200},
        "parameters": {
          "distance": {"param": "length_with_overhang"}
        }
      },
      {
        "id": "orient_roof",
        "type": "transform.basic.rotate",
        "position": {"x": 650, "y": 200},
        "parameters": {
          "axis": {"x": 1, "y": 0, "z": 0},
          "angle": 90
        }
      },
      {
        "id": "move_to_pos",
        "type": "transform.basic.move",
        "position": {"x": 850, "y": 200},
        "parameters": {}
      },
      {
        "id": "assign_material",
        "type": "material.basic_assignment.assign_block_type",
        "position": {"x": 1050, "y": 200},
        "parameters": {
          "block_type": {"param": "roof_material"}
        }
      },
      {
        "id": "bake",
        "type": "output.bake.geometry_to_blocks",
        "position": {"x": 1250, "y": 200},
        "parameters": {
          "placement_mode": "shell"
        }
      },
      {
        "id": "preview",
        "type": "output.preview.preview_blocks",
        "position": {"x": 1450, "y": 200},
        "parameters": {}
      }
    ],
    "connections": [
      {
        "from": {"node": "roof_profile", "port": "profile"},
        "to": {"node": "extrude_roof", "port": "profile"}
      },
      {
        "from": {"node": "extrude_roof", "port": "geometry"},
        "to": {"node": "orient_roof", "port": "geometry"}
      },
      {
        "from": {"node": "orient_roof", "port": "geometry"},
        "to": {"node": "move_to_pos", "port": "geometry"}
      },
      {
        "from": {"node": "input_pos", "port": "position"},
        "to": {"node": "move_to_pos", "port": "translation"}
      },
      {
        "from": {"node": "move_to_pos", "port": "geometry"},
        "to": {"node": "assign_material", "port": "geometry"}
      },
      {
        "from": {"node": "assign_material", "port": "geometry"},
        "to": {"node": "bake", "port": "geometry"}
      },
      {
        "from": {"node": "bake", "port": "blocks"},
        "to": {"node": "preview", "port": "blocks"}
      }
    ]
  },

  "documentation": {
    "learning_notes": "This preset demonstrates profile extrusion and transformation. A triangular profile is extruded along a length, then rotated to create the pitched roof shape.",
    "tips": [
      "Lower pitch creates flatter roofs (modern style)",
      "Higher pitch is better for snow-prone areas",
      "Overhang protects walls from rain",
      "Use stairs blocks for realistic roof texture",
      "Different wood types for varied aesthetics"
    ],
    "related_presets": [
      "building_elements.roofs.hip_roof",
      "quickstart.basic_house"
    ]
  }
}
