{
  "preset_id": "building_elements.doors.simple_door",
  "version": "1.0.0",
  "schema_version": "1.0",

  "metadata": {
    "name": "Simple Door Frame",
    "name_i18n": {
      "zh_CN": "简单门框",
      "en_US": "Simple Door Frame"
    },
    "description": "A basic door frame with threshold and lintel.",
    "description_i18n": {
      "zh_CN": "带有门槛和过梁的基本门框。",
      "en_US": "A basic door frame with threshold and lintel."
    },
    "author": "NodeCraft Team",
    "tags": ["door", "doorway", "entrance", "building-element"],
    "category": "building_elements",
    "difficulty": "beginner",
    "estimated_build_time": "1 minute",
    "estimated_node_count": 4
  },

  "thumbnails": {
    "main": "thumbnail.png",
    "previews": []
  },

  "parameters": [
    {
      "id": "width",
      "name": "Door Width",
      "type": "integer",
      "default": 2,
      "min": 1,
      "max": 4,
      "step": 1,
      "description": "Width of the door opening",
      "group": "Dimensions"
    },
    {
      "id": "height",
      "name": "Door Height",
      "type": "integer",
      "default": 3,
      "min": 2,
      "max": 5,
      "step": 1,
      "description": "Height of the door opening",
      "group": "Dimensions"
    },
    {
      "id": "depth",
      "name": "Frame Depth",
      "type": "integer",
      "default": 1,
      "min": 1,
      "max": 3,
      "step": 1,
      "description": "Depth of the door frame",
      "group": "Dimensions"
    },
    {
      "id": "frame_material",
      "name": "Frame Material",
      "type": "block_selector",
      "default": "minecraft:oak_planks",
      "description": "Block type for door frame",
      "group": "Materials"
    }
  },

  "graph": {
    "nodes": [
      {
        "id": "input_pos",
        "type": "input.context.player_position",
        "position": {"x": 50, "y": 200},
        "parameters": {}
      },
      {
        "id": "door_opening",
        "type": "geometry.primitives.box_by_corner_and_size",
        "position": {"x": 250, "y": 200},
        "parameters": {
          "corner": {"x": 0, "y": 0, "z": 0},
          "size": {
            "x": {"param": "width"},
            "y": {"param": "height"},
            "z": {"param": "depth"}
          }
        }
      },
      {
        "id": "assign_material",
        "type": "material.basic_assignment.assign_block_type",
        "position": {"x": 450, "y": 200},
        "parameters": {
          "block_type": {"param": "frame_material"}
        }
      },
      {
        "id": "move_to_pos",
        "type": "transform.basic.move",
        "position": {"x": 650, "y": 200},
        "parameters": {}
      },
      {
        "id": "bake",
        "type": "output.bake.geometry_to_blocks",
        "position": {"x": 850, "y": 200},
        "parameters": {
          "placement_mode": "shell"
        }
      },
      {
        "id": "preview",
        "type": "output.preview.preview_blocks",
        "position": {"x": 1050, "y": 200},
        "parameters": {}
      }
    ],
    "connections": [
      {
        "from": {"node": "door_opening", "port": "geometry"},
        "to": {"node": "assign_material", "port": "geometry"}
      },
      {
        "from": {"node": "assign_material", "port": "geometry"},
        "to": {"node": "move_to_pos", "port": "geometry"}
      },
      {
        "from": {"node": "input_pos", "port": "position"},
        "to": {"node": "move_to_pos", "port": "translation"}
      },
      {
        "from": {"node": "move_to_pos", "port": "geometry"},
        "to": {"node": "bake", "port": "geometry"}
      },
      {
        "from": {"node": "bake", "port": "blocks"},
        "to": {"node": "preview", "port": "blocks"}
      }
    ]
  },

  "documentation": {
    "learning_notes": "This is a minimalist door frame preset. Use it as a cutout in walls or enhance with decorative elements.",
    "tips": [
      "Standard door is 2 wide x 3 tall",
      "Double doors need 3-4 block width",
      "Use same material as wall for seamless look",
      "Add decorative blocks above for lintel detail",
      "Place actual door blocks manually after baking"
    ],
    "related_presets": [
      "building_elements.windows.modern_window",
      "quickstart.garden_wall"
    ]
  }
}
