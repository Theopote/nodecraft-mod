{
  "preset_id": "styles.modern.glass_box_building",
  "version": "1.0.0",
  "schema_version": "1.0",

  "metadata": {
    "name": "Modern Glass Box Building",
    "name_i18n": {
      "zh_CN": "现代玻璃盒子建筑",
      "en_US": "Modern Glass Box Building"
    },
    "description": "A sleek modern building with glass walls and concrete frame, perfect for contemporary city builds.",
    "description_i18n": {
      "zh_CN": "带有玻璃墙和混凝土框架的时尚现代建筑，非常适合现代城市建造。",
      "en_US": "A sleek modern building with glass walls and concrete frame, perfect for contemporary city builds."
    },
    "author": "NodeCraft Team",
    "tags": ["modern", "glass", "contemporary", "urban"],
    "category": "styles",
    "difficulty": "intermediate",
    "estimated_build_time": "4 minutes",
    "estimated_node_count": 15
  },

  "thumbnails": {
    "main": "thumbnail.png",
    "previews": []
  },

  "parameters": [
    {
      "id": "width",
      "name": "Building Width",
      "type": "integer",
      "default": 12,
      "min": 8,
      "max": 32,
      "step": 1,
      "description": "Width of the building",
      "group": "Dimensions"
    },
    {
      "id": "length",
      "name": "Building Length",
      "type": "integer",
      "default": 16,
      "min": 8,
      "max": 32,
      "step": 1,
      "description": "Length of the building",
      "group": "Dimensions"
    },
    {
      "id": "floors",
      "name": "Number of Floors",
      "type": "integer",
      "default": 3,
      "min": 1,
      "max": 10,
      "step": 1,
      "description": "Number of stories",
      "group": "Dimensions"
    },
    {
      "id": "floor_height",
      "name": "Floor Height",
      "type": "integer",
      "default": 4,
      "min": 3,
      "max": 6,
      "step": 1,
      "description": "Height of each floor",
      "group": "Dimensions"
    },
    {
      "id": "frame_material",
      "name": "Frame Material",
      "type": "block_selector",
      "default": "minecraft:smooth_stone",
      "description": "Block type for structural frame",
      "group": "Materials"
    },
    {
      "id": "glass_material",
      "name": "Glass Material",
      "type": "block_selector",
      "default": "minecraft:glass",
      "description": "Block type for glass walls",
      "group": "Materials"
    },
    {
      "id": "floor_material",
      "name": "Floor Material",
      "type": "block_selector",
      "default": "minecraft:white_concrete",
      "description": "Block type for floors",
      "group": "Materials"
    },
    {
      "id": "flat_roof",
      "name": "Flat Roof",
      "type": "boolean",
      "default": true,
      "description": "Use flat roof instead of pitched",
      "group": "Style"
    }
  ],

  "graph": {
    "nodes": [
      {
        "id": "input_pos",
        "type": "input.context.player_position",
        "position": {"x": 50, "y": 300},
        "parameters": {}
      },
      {
        "id": "building_volume",
        "type": "geometry.primitives.box_by_corner_and_size",
        "position": {"x": 250, "y": 250},
        "parameters": {
          "corner": {"x": 0, "y": 0, "z": 0},
          "size": {
            "x": {"param": "width"},
            "y": {"param": "total_height"},
            "z": {"param": "length"}
          }
        }
      },
      {
        "id": "interior_volume",
        "type": "geometry.primitives.box_by_corner_and_size",
        "position": {"x": 250, "y": 370},
        "parameters": {
          "corner": {"x": 0.5, "y": 0, "z": 0.5},
          "size": {
            "x": {"param": "width_minus_walls"},
            "y": {"param": "total_height"},
            "z": {"param": "length_minus_walls"}
          }
        }
      },
      {
        "id": "hollow_building",
        "type": "geometry.boolean.difference",
        "position": {"x": 450, "y": 310},
        "parameters": {}
      },
      {
        "id": "corner_frame_1",
        "type": "geometry.primitives.box_by_corner_and_size",
        "position": {"x": 250, "y": 520},
        "parameters": {
          "corner": {"x": 0, "y": 0, "z": 0},
          "size": {"x": 1, "y": {"param": "total_height"}, "z": 1}
        }
      },
      {
        "id": "corner_frame_2",
        "type": "geometry.primitives.box_by_corner_and_size",
        "position": {"x": 250, "y": 620},
        "parameters": {
          "corner": {
            "x": {"param": "width_minus_one"},
            "y": 0,
            "z": 0
          },
          "size": {"x": 1, "y": {"param": "total_height"}, "z": 1}
        }
      },
      {
        "id": "corner_frame_3",
        "type": "geometry.primitives.box_by_corner_and_size",
        "position": {"x": 250, "y": 720},
        "parameters": {
          "corner": {
            "x": 0,
            "y": 0,
            "z": {"param": "length_minus_one"}
          },
          "size": {"x": 1, "y": {"param": "total_height"}, "z": 1}
        }
      },
      {
        "id": "corner_frame_4",
        "type": "geometry.primitives.box_by_corner_and_size",
        "position": {"x": 250, "y": 820},
        "parameters": {
          "corner": {
            "x": {"param": "width_minus_one"},
            "y": 0,
            "z": {"param": "length_minus_one"}
          },
          "size": {"x": 1, "y": {"param": "total_height"}, "z": 1}
        }
      },
      {
        "id": "union_frames",
        "type": "geometry.boolean.union_multiple",
        "position": {"x": 650, "y": 650},
        "parameters": {}
      },
      {
        "id": "union_all",
        "type": "geometry.boolean.union",
        "position": {"x": 850, "y": 450},
        "parameters": {}
      },
      {
        "id": "assign_glass_walls",
        "type": "material.basic_assignment.assign_block_type",
        "position": {"x": 1050, "y": 450},
        "parameters": {
          "block_type": {"param": "glass_material"}
        }
      },
      {
        "id": "assign_frame",
        "type": "material.gradient_mapping.height_gradient",
        "position": {"x": 1250, "y": 450},
        "parameters": {
          "stops": [
            {"height": 0, "block": {"param": "frame_material"}}
          ]
        }
      },
      {
        "id": "move_to_pos",
        "type": "transform.basic.move",
        "position": {"x": 1450, "y": 450},
        "parameters": {}
      },
      {
        "id": "bake",
        "type": "output.bake.geometry_to_blocks",
        "position": {"x": 1650, "y": 450},
        "parameters": {
          "placement_mode": "shell"
        }
      },
      {
        "id": "preview",
        "type": "output.preview.preview_blocks",
        "position": {"x": 1850, "y": 450},
        "parameters": {}
      }
    ],
    "connections": [
      {
        "from": {"node": "building_volume", "port": "geometry"},
        "to": {"node": "hollow_building", "port": "a"}
      },
      {
        "from": {"node": "interior_volume", "port": "geometry"},
        "to": {"node": "hollow_building", "port": "b"}
      },
      {
        "from": {"node": "corner_frame_1", "port": "geometry"},
        "to": {"node": "union_frames", "port": "geometries"}
      },
      {
        "from": {"node": "corner_frame_2", "port": "geometry"},
        "to": {"node": "union_frames", "port": "geometries"}
      },
      {
        "from": {"node": "corner_frame_3", "port": "geometry"},
        "to": {"node": "union_frames", "port": "geometries"}
      },
      {
        "from": {"node": "corner_frame_4", "port": "geometry"},
        "to": {"node": "union_frames", "port": "geometries"}
      },
      {
        "from": {"node": "hollow_building", "port": "result"},
        "to": {"node": "union_all", "port": "a"}
      },
      {
        "from": {"node": "union_frames", "port": "result"},
        "to": {"node": "union_all", "port": "b"}
      },
      {
        "from": {"node": "union_all", "port": "result"},
        "to": {"node": "assign_glass_walls", "port": "geometry"}
      },
      {
        "from": {"node": "assign_glass_walls", "port": "geometry"},
        "to": {"node": "assign_frame", "port": "geometry"}
      },
      {
        "from": {"node": "assign_frame", "port": "geometry"},
        "to": {"node": "move_to_pos", "port": "geometry"}
      },
      {
        "from": {"node": "input_pos", "port": "position"},
        "to": {"node": "move_to_pos", "port": "translation"}
      },
      {
        "from": {"node": "move_to_pos", "port": "geometry"},
        "to": {"node": "bake", "port": "geometry"}
      },
      {
        "from": {"node": "bake", "port": "blocks"},
        "to": {"node": "preview", "port": "blocks"}
      }
    ]
  },

  "documentation": {
    "learning_notes": "This preset demonstrates modern architectural design with glass curtain walls and structural frame elements at corners. The building is hollow with glass infill.",
    "tips": [
      "Perfect for office buildings and modern homes",
      "Use different glass colors for varied effects",
      "Concrete or stone work well for frames",
      "Multiple floors create impressive skyscrapers",
      "Add interior floors manually after baking"
    ],
    "related_presets": [
      "quickstart.basic_box",
      "architectural.residential.medieval_cottage"
    ]
  }
}
