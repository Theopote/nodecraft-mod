{
  "preset_id": "architectural.infrastructure.watchtower",
  "version": "1.0.0",
  "schema_version": "1.0",

  "metadata": {
    "name": "Medieval Watchtower",
    "name_i18n": {
      "zh_CN": "中世纪瞭望塔",
      "en_US": "Medieval Watchtower"
    },
    "description": "A defensive watchtower with crenellations and observation deck.",
    "description_i18n": {
      "zh_CN": "带有雉堞和观察台的防御瞭望塔。",
      "en_US": "A defensive watchtower with crenellations and observation deck."
    },
    "author": "NodeCraft Team",
    "tags": ["tower", "watchtower", "medieval", "defensive"],
    "category": "architectural",
    "difficulty": "intermediate",
    "estimated_build_time": "3 minutes",
    "estimated_node_count": 10
  },

  "thumbnails": {
    "main": "thumbnail.png",
    "previews": []
  },

  "parameters": [
    {
      "id": "height",
      "name": "Tower Height",
      "type": "integer",
      "default": 16,
      "min": 8,
      "max": 32,
      "step": 2,
      "description": "Height of the tower",
      "group": "Dimensions"
    },
    {
      "id": "base_size",
      "name": "Base Size",
      "type": "integer",
      "default": 6,
      "min": 4,
      "max": 10,
      "step": 1,
      "description": "Size of the square base",
      "group": "Dimensions"
    },
    {
      "id": "wall_thickness",
      "name": "Wall Thickness",
      "type": "integer",
      "default": 1,
      "min": 1,
      "max": 2,
      "step": 1,
      "description": "Thickness of walls",
      "group": "Dimensions"
    },
    {
      "id": "tower_material",
      "name": "Tower Material",
      "type": "block_selector",
      "default": "minecraft:stone_bricks",
      "description": "Block type for tower structure",
      "group": "Materials"
    },
    {
      "id": "battlement_material",
      "name": "Battlement Material",
      "type": "block_selector",
      "default": "minecraft:cobblestone",
      "description": "Block type for top battlements",
      "group": "Materials"
    }
  ],

  "graph": {
    "nodes": [
      {
        "id": "input_pos",
        "type": "input.context.player_position",
        "position": {"x": 50, "y": 250},
        "parameters": {}
      },
      {
        "id": "outer_tower",
        "type": "geometry.primitives.box_by_corner_and_size",
        "position": {"x": 250, "y": 200},
        "parameters": {
          "corner": {"x": 0, "y": 0, "z": 0},
          "size": {
            "x": {"param": "base_size"},
            "y": {"param": "height"},
            "z": {"param": "base_size"}
          }
        }
      },
      {
        "id": "inner_tower",
        "type": "geometry.primitives.box_by_corner_and_size",
        "position": {"x": 250, "y": 320},
        "parameters": {
          "corner": {
            "x": {"param": "wall_thickness"},
            "y": 0,
            "z": {"param": "wall_thickness"}
          },
          "size": {
            "x": {"param": "inner_size"},
            "y": {"param": "height"},
            "z": {"param": "inner_size"}
          }
        }
      },
      {
        "id": "hollow_tower",
        "type": "geometry.boolean.difference",
        "position": {"x": 450, "y": 260},
        "parameters": {}
      },
      {
        "id": "battlement_1",
        "type": "geometry.primitives.box_by_corner_and_size",
        "position": {"x": 250, "y": 460},
        "parameters": {
          "corner": {
            "x": 0,
            "y": {"param": "height"},
            "z": 0
          },
          "size": {"x": 2, "y": 2, "z": 2}
        }
      },
      {
        "id": "battlement_2",
        "type": "geometry.primitives.box_by_corner_and_size",
        "position": {"x": 250, "y": 560},
        "parameters": {
          "corner": {
            "x": {"param": "battlement_x2"},
            "y": {"param": "height"},
            "z": 0
          },
          "size": {"x": 2, "y": 2, "z": 2}
        }
      },
      {
        "id": "battlement_3",
        "type": "geometry.primitives.box_by_corner_and_size",
        "position": {"x": 250, "y": 660},
        "parameters": {
          "corner": {
            "x": 0,
            "y": {"param": "height"},
            "z": {"param": "battlement_z2"}
          },
          "size": {"x": 2, "y": 2, "z": 2}
        }
      },
      {
        "id": "battlement_4",
        "type": "geometry.primitives.box_by_corner_and_size",
        "position": {"x": 250, "y": 760},
        "parameters": {
          "corner": {
            "x": {"param": "battlement_x2"},
            "y": {"param": "height"},
            "z": {"param": "battlement_z2"}
          },
          "size": {"x": 2, "y": 2, "z": 2}
        }
      },
      {
        "id": "union_all",
        "type": "geometry.boolean.union_multiple",
        "position": {"x": 650, "y": 500},
        "parameters": {}
      },
      {
        "id": "assign_material",
        "type": "material.basic_assignment.assign_block_type",
        "position": {"x": 850, "y": 500},
        "parameters": {
          "block_type": {"param": "tower_material"}
        }
      },
      {
        "id": "move_to_pos",
        "type": "transform.basic.move",
        "position": {"x": 1050, "y": 500},
        "parameters": {}
      },
      {
        "id": "bake",
        "type": "output.bake.geometry_to_blocks",
        "position": {"x": 1250, "y": 500},
        "parameters": {
          "placement_mode": "solid"
        }
      },
      {
        "id": "preview",
        "type": "output.preview.preview_blocks",
        "position": {"x": 1450, "y": 500},
        "parameters": {}
      }
    ],
    "connections": [
      {
        "from": {"node": "outer_tower", "port": "geometry"},
        "to": {"node": "hollow_tower", "port": "a"}
      },
      {
        "from": {"node": "inner_tower", "port": "geometry"},
        "to": {"node": "hollow_tower", "port": "b"}
      },
      {
        "from": {"node": "hollow_tower", "port": "result"},
        "to": {"node": "union_all", "port": "geometries"}
      },
      {
        "from": {"node": "battlement_1", "port": "geometry"},
        "to": {"node": "union_all", "port": "geometries"}
      },
      {
        "from": {"node": "battlement_2", "port": "geometry"},
        "to": {"node": "union_all", "port": "geometries"}
      },
      {
        "from": {"node": "battlement_3", "port": "geometry"},
        "to": {"node": "union_all", "port": "geometries"}
      },
      {
        "from": {"node": "battlement_4", "port": "geometry"},
        "to": {"node": "union_all", "port": "geometries"}
      },
      {
        "from": {"node": "union_all", "port": "result"},
        "to": {"node": "assign_material", "port": "geometry"}
      },
      {
        "from": {"node": "assign_material", "port": "geometry"},
        "to": {"node": "move_to_pos", "port": "geometry"}
      },
      {
        "from": {"node": "input_pos", "port": "position"},
        "to": {"node": "move_to_pos", "port": "translation"}
      },
      {
        "from": {"node": "move_to_pos", "port": "geometry"},
        "to": {"node": "bake", "port": "geometry"}
      },
      {
        "from": {"node": "bake", "port": "blocks"},
        "to": {"node": "preview", "port": "blocks"}
      }
    ]
  },

  "documentation": {
    "learning_notes": "This preset demonstrates defensive architecture with corner battlements (crenellations) for protection. The hollow interior allows for stairs and storage.",
    "tips": [
      "Place at strategic locations for defense",
      "Add interior stairs using straight staircase preset",
      "Battlements provide cover for archers",
      "Taller towers provide better visibility",
      "Connect to walls for fortifications"
    ],
    "related_presets": [
      "quickstart.simple_tower",
      "styles.medieval.castle_keep"
    ]
  }
}
