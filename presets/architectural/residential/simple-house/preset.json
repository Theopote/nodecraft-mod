{
  "preset_id": "architectural.residential.simple_house",
  "version": "1.0.0",
  "schema_version": "1.0",

  "metadata": {
    "name": "Simple Modern House",
    "name_i18n": {
      "zh_CN": "简单现代住宅",
      "en_US": "Simple Modern House"
    },
    "description": "A clean, modern single-story house with flat roof and large windows.",
    "description_i18n": {
      "zh_CN": "带有平屋顶和大窗户的简洁现代单层住宅。",
      "en_US": "A clean, modern single-story house with flat roof and large windows."
    },
    "author": "NodeCraft Team",
    "tags": ["house", "modern", "residential", "simple"],
    "category": "architectural",
    "difficulty": "beginner",
    "estimated_build_time": "3 minutes",
    "estimated_node_count": 8
  },

  "thumbnails": {
    "main": "thumbnail.png",
    "previews": []
  },

  "parameters": [
    {
      "id": "width",
      "name": "House Width",
      "type": "integer",
      "default": 10,
      "min": 6,
      "max": 20,
      "step": 1,
      "description": "Width of the house",
      "group": "Dimensions"
    },
    {
      "id": "length",
      "name": "House Length",
      "type": "integer",
      "default": 12,
      "min": 6,
      "max": 20,
      "step": 1,
      "description": "Length of the house",
      "group": "Dimensions"
    },
    {
      "id": "height",
      "name": "Wall Height",
      "type": "integer",
      "default": 4,
      "min": 3,
      "max": 6,
      "step": 1,
      "description": "Height of the walls",
      "group": "Dimensions"
    },
    {
      "id": "wall_material",
      "name": "Wall Material",
      "type": "block_selector",
      "default": "minecraft:white_concrete",
      "description": "Block type for walls",
      "group": "Materials"
    },
    {
      "id": "roof_material",
      "name": "Roof Material",
      "type": "block_selector",
      "default": "minecraft:gray_concrete",
      "description": "Block type for flat roof",
      "group": "Materials"
    },
    {
      "id": "window_material",
      "name": "Window Material",
      "type": "block_selector",
      "default": "minecraft:glass",
      "description": "Block type for windows",
      "group": "Materials"
    }
  ],

  "graph": {
    "nodes": [
      {
        "id": "input_pos",
        "type": "input.context.player_position",
        "position": {"x": 50, "y": 250},
        "parameters": {}
      },
      {
        "id": "outer_box",
        "type": "geometry.primitives.box_by_corner_and_size",
        "position": {"x": 250, "y": 200},
        "parameters": {
          "corner": {"x": 0, "y": 0, "z": 0},
          "size": {
            "x": {"param": "width"},
            "y": {"param": "height"},
            "z": {"param": "length"}
          }
        }
      },
      {
        "id": "inner_box",
        "type": "geometry.primitives.box_by_corner_and_size",
        "position": {"x": 250, "y": 320},
        "parameters": {
          "corner": {"x": 0.5, "y": 0, "z": 0.5},
          "size": {
            "x": {"param": "width_inner"},
            "y": {"param": "height"},
            "z": {"param": "length_inner"}
          }
        }
      },
      {
        "id": "hollow_house",
        "type": "geometry.boolean.difference",
        "position": {"x": 450, "y": 260},
        "parameters": {}
      },
      {
        "id": "roof",
        "type": "geometry.primitives.box_by_corner_and_size",
        "position": {"x": 250, "y": 460},
        "parameters": {
          "corner": {
            "x": 0,
            "y": {"param": "height"},
            "z": 0
          },
          "size": {
            "x": {"param": "width"},
            "y": 0.5,
            "z": {"param": "length"}
          }
        }
      },
      {
        "id": "union_all",
        "type": "geometry.boolean.union",
        "position": {"x": 650, "y": 350},
        "parameters": {}
      },
      {
        "id": "assign_material",
        "type": "material.gradient_mapping.height_gradient",
        "position": {"x": 850, "y": 350},
        "parameters": {
          "stops": [
            {"height": 0, "block": {"param": "wall_material"}},
            {"height": {"param": "height"}, "block": {"param": "roof_material"}}
          ]
        }
      },
      {
        "id": "move_to_pos",
        "type": "transform.basic.move",
        "position": {"x": 1050, "y": 350},
        "parameters": {}
      },
      {
        "id": "bake",
        "type": "output.bake.geometry_to_blocks",
        "position": {"x": 1250, "y": 350},
        "parameters": {
          "placement_mode": "shell"
        }
      },
      {
        "id": "preview",
        "type": "output.preview.preview_blocks",
        "position": {"x": 1450, "y": 350},
        "parameters": {}
      }
    ],
    "connections": [
      {
        "from": {"node": "outer_box", "port": "geometry"},
        "to": {"node": "hollow_house", "port": "a"}
      },
      {
        "from": {"node": "inner_box", "port": "geometry"},
        "to": {"node": "hollow_house", "port": "b"}
      },
      {
        "from": {"node": "hollow_house", "port": "result"},
        "to": {"node": "union_all", "port": "a"}
      },
      {
        "from": {"node": "roof", "port": "geometry"},
        "to": {"node": "union_all", "port": "b"}
      },
      {
        "from": {"node": "union_all", "port": "result"},
        "to": {"node": "assign_material", "port": "geometry"}
      },
      {
        "from": {"node": "assign_material", "port": "geometry"},
        "to": {"node": "move_to_pos", "port": "geometry"}
      },
      {
        "from": {"node": "input_pos", "port": "position"},
        "to": {"node": "move_to_pos", "port": "translation"}
      },
      {
        "from": {"node": "move_to_pos", "port": "geometry"},
        "to": {"node": "bake", "port": "geometry"}
      },
      {
        "from": {"node": "bake", "port": "blocks"},
        "to": {"node": "preview", "port": "blocks"}
      }
    ]
  },

  "documentation": {
    "learning_notes": "This preset demonstrates modern minimalist architecture with clean lines and a flat roof. Perfect for contemporary city builds.",
    "tips": [
      "Use concrete for modern aesthetic",
      "Add large glass walls for natural light",
      "Flat roofs are characteristic of modern design",
      "Simple geometric forms create clean look",
      "Place in modern city or suburban settings"
    ],
    "related_presets": [
      "styles.modern.glass_box_building",
      "architectural.residential.medieval_cottage"
    ]
  }
}
