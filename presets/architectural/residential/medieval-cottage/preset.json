{
  "preset_id": "architectural.residential.medieval_cottage",
  "version": "1.0.0",
  "schema_version": "1.0",

  "metadata": {
    "name": "Medieval Cottage",
    "name_i18n": {
      "zh_CN": "中世纪小屋",
      "en_US": "Medieval Cottage"
    },
    "description": "A cozy medieval cottage with timber frame, stone foundation, and pitched roof.",
    "description_i18n": {
      "zh_CN": "带有木框架、石基和斜屋顶的温馨中世纪小屋。",
      "en_US": "A cozy medieval cottage with timber frame, stone foundation, and pitched roof."
    },
    "author": "NodeCraft Team",
    "tags": ["cottage", "medieval", "house", "residential"],
    "category": "architectural",
    "difficulty": "intermediate",
    "estimated_build_time": "5 minutes",
    "estimated_node_count": 18
  },

  "thumbnails": {
    "main": "thumbnail.png",
    "previews": []
  },

  "parameters": [
    {
      "id": "width",
      "name": "Building Width",
      "type": "integer",
      "default": 8,
      "min": 6,
      "max": 16,
      "step": 1,
      "description": "Width of the cottage",
      "group": "Dimensions"
    },
    {
      "id": "length",
      "name": "Building Length",
      "type": "integer",
      "default": 10,
      "min": 6,
      "max": 16,
      "step": 1,
      "description": "Length of the cottage",
      "group": "Dimensions"
    },
    {
      "id": "wall_height",
      "name": "Wall Height",
      "type": "integer",
      "default": 4,
      "min": 3,
      "max": 6,
      "step": 1,
      "description": "Height of the walls",
      "group": "Dimensions"
    },
    {
      "id": "foundation_material",
      "name": "Foundation Material",
      "type": "block_selector",
      "default": "minecraft:cobblestone",
      "description": "Block type for foundation",
      "group": "Materials"
    },
    {
      "id": "wall_material",
      "name": "Wall Material",
      "type": "block_selector",
      "default": "minecraft:oak_planks",
      "description": "Block type for walls",
      "group": "Materials"
    },
    {
      "id": "frame_material",
      "name": "Frame Material",
      "type": "block_selector",
      "default": "minecraft:oak_log",
      "description": "Block type for timber frame",
      "group": "Materials"
    },
    {
      "id": "roof_material",
      "name": "Roof Material",
      "type": "block_selector",
      "default": "minecraft:oak_stairs",
      "description": "Block type for roof",
      "group": "Materials"
    },
    {
      "id": "add_chimney",
      "name": "Add Chimney",
      "type": "boolean",
      "default": true,
      "description": "Whether to add a stone chimney",
      "group": "Features"
    }
  ],

  "graph": {
    "nodes": [
      {
        "id": "input_pos",
        "type": "input.context.player_position",
        "position": {"x": 50, "y": 300},
        "parameters": {}
      },
      {
        "id": "foundation",
        "type": "geometry.primitives.box_by_corner_and_size",
        "position": {"x": 250, "y": 150},
        "parameters": {
          "size": {
            "x": {"param": "width"},
            "y": 1,
            "z": {"param": "length"}
          }
        }
      },
      {
        "id": "walls_outer",
        "type": "geometry.primitives.box_by_corner_and_size",
        "position": {"x": 250, "y": 250},
        "parameters": {
          "size": {
            "x": {"param": "width"},
            "y": {"param": "wall_height"},
            "z": {"param": "length"}
          }
        }
      },
      {
        "id": "walls_inner",
        "type": "geometry.primitives.box_by_corner_and_size",
        "position": {"x": 250, "y": 350},
        "parameters": {
          "size": {
            "x": {"param": "width_inner"},
            "y": {"param": "wall_height"},
            "z": {"param": "length_inner"}
          }
        }
      },
      {
        "id": "hollow_walls",
        "type": "geometry.boolean.difference",
        "position": {"x": 450, "y": 300},
        "parameters": {}
      },
      {
        "id": "door_opening",
        "type": "geometry.primitives.box_by_corner_and_size",
        "position": {"x": 250, "y": 500},
        "parameters": {
          "corner": {
            "x": {"param": "door_x"},
            "y": 0,
            "z": 0
          },
          "size": {"x": 2, "y": 3, "z": 1}
        }
      },
      {
        "id": "cut_door",
        "type": "geometry.boolean.difference",
        "position": {"x": 650, "y": 350},
        "parameters": {}
      },
      {
        "id": "window1",
        "type": "geometry.primitives.box_by_corner_and_size",
        "position": {"x": 250, "y": 600},
        "parameters": {
          "corner": {
            "x": {"param": "window1_x"},
            "y": 2,
            "z": 0
          },
          "size": {"x": 2, "y": 2, "z": 1}
        }
      },
      {
        "id": "cut_windows",
        "type": "geometry.boolean.difference",
        "position": {"x": 850, "y": 400},
        "parameters": {}
      },
      {
        "id": "roof_profile",
        "type": "geometry.profiles.triangle",
        "position": {"x": 250, "y": 750},
        "parameters": {
          "width": {"param": "width_plus_overhang"},
          "height": {"param": "roof_height"}
        }
      },
      {
        "id": "extrude_roof",
        "type": "geometry.solids.extrude",
        "position": {"x": 450, "y": 750},
        "parameters": {
          "distance": {"param": "length_plus_overhang"}
        }
      },
      {
        "id": "position_roof",
        "type": "transform.basic.move",
        "position": {"x": 650, "y": 750},
        "parameters": {
          "translation": {
            "x": 0,
            "y": {"param": "wall_height"},
            "z": 0
          }
        }
      },
      {
        "id": "union_building",
        "type": "geometry.boolean.union_multiple",
        "position": {"x": 1050, "y": 450},
        "parameters": {}
      },
      {
        "id": "assign_foundation",
        "type": "material.gradient_mapping.height_gradient",
        "position": {"x": 1250, "y": 450},
        "parameters": {
          "stops": [
            {"height": 0, "block": {"param": "foundation_material"}},
            {"height": 1, "block": {"param": "wall_material"}},
            {"height": {"param": "wall_height"}, "block": {"param": "roof_material"}}
          ]
        }
      },
      {
        "id": "move_to_position",
        "type": "transform.basic.move",
        "position": {"x": 1450, "y": 450},
        "parameters": {}
      },
      {
        "id": "bake",
        "type": "output.bake.geometry_to_blocks",
        "position": {"x": 1650, "y": 450},
        "parameters": {
          "placement_mode": "solid"
        }
      },
      {
        "id": "preview",
        "type": "output.preview.preview_blocks",
        "position": {"x": 1850, "y": 450},
        "parameters": {}
      }
    ],
    "connections": [
      {
        "from": {"node": "walls_outer", "port": "geometry"},
        "to": {"node": "hollow_walls", "port": "a"}
      },
      {
        "from": {"node": "walls_inner", "port": "geometry"},
        "to": {"node": "hollow_walls", "port": "b"}
      },
      {
        "from": {"node": "hollow_walls", "port": "result"},
        "to": {"node": "cut_door", "port": "a"}
      },
      {
        "from": {"node": "door_opening", "port": "geometry"},
        "to": {"node": "cut_door", "port": "b"}
      },
      {
        "from": {"node": "cut_door", "port": "result"},
        "to": {"node": "cut_windows", "port": "a"}
      },
      {
        "from": {"node": "window1", "port": "geometry"},
        "to": {"node": "cut_windows", "port": "b"}
      },
      {
        "from": {"node": "roof_profile", "port": "profile"},
        "to": {"node": "extrude_roof", "port": "profile"}
      },
      {
        "from": {"node": "extrude_roof", "port": "geometry"},
        "to": {"node": "position_roof", "port": "geometry"}
      },
      {
        "from": {"node": "foundation", "port": "geometry"},
        "to": {"node": "union_building", "port": "geometries"}
      },
      {
        "from": {"node": "cut_windows", "port": "result"},
        "to": {"node": "union_building", "port": "geometries"}
      },
      {
        "from": {"node": "position_roof", "port": "geometry"},
        "to": {"node": "union_building", "port": "geometries"}
      },
      {
        "from": {"node": "union_building", "port": "result"},
        "to": {"node": "assign_foundation", "port": "geometry"}
      },
      {
        "from": {"node": "assign_foundation", "port": "geometry"},
        "to": {"node": "move_to_position", "port": "geometry"}
      },
      {
        "from": {"node": "input_pos", "port": "position"},
        "to": {"node": "move_to_position", "port": "translation"}
      },
      {
        "from": {"node": "move_to_position", "port": "geometry"},
        "to": {"node": "bake", "port": "geometry"}
      },
      {
        "from": {"node": "bake", "port": "blocks"},
        "to": {"node": "preview", "port": "blocks"}
      }
    ]
  },

  "documentation": {
    "learning_notes": "This preset demonstrates a complete building workflow: foundation, hollow walls with openings, roof generation, and multi-material assignment using height gradients.",
    "tips": [
      "Foundation provides stability on uneven terrain",
      "Hollow walls save blocks and allow interior space",
      "Height gradient assigns different materials by elevation",
      "Adjust wall height for multi-story buildings",
      "Use different wood types for varied aesthetics"
    ],
    "related_presets": [
      "quickstart.basic_house",
      "building_elements.roofs.gable_roof"
    ]
  }
}
